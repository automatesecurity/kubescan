{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://automatesecurity.github.io/kubescan/schemas/kubescan.automatesecurity.github.io/advisory-bundle/v1alpha1",
  "title": "Kubescan Advisory Bundle",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "apiVersion",
    "kind",
    "advisories"
  ],
  "properties": {
    "apiVersion": {
      "const": "kubescan.automatesecurity.github.io/v1alpha1"
    },
    "kind": {
      "const": "AdvisoryBundle"
    },
    "advisories": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/advisory"
      }
    }
  },
  "$defs": {
    "advisory": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "packageName",
        "ecosystem",
        "affectedVersions",
        "severity",
        "summary"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "aliases": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "packageName": {
          "type": "string"
        },
        "ecosystem": {
          "type": "string"
        },
        "affectedVersions": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "fixedVersion": {
          "type": "string"
        },
        "severity": {
          "enum": [
            "low",
            "medium",
            "high",
            "critical"
          ]
        },
        "summary": {
          "type": "string"
        }
      }
    }
  }
}

